# ============================================
# Конфигурация yamllint
# ============================================
# yamllint — линтер для YAML-файлов
# Расширяет базовые правила и добавляет кастомные
# ============================================

extends:
  # Использовать базовый набор правил
  default

rules:
  document-start: disable
  truthy: disable
  line-length:
    # Максимум 120 символов
    max: 120
    # Предупреждение вместо ошибки
    level: warning
  
  # Правила для комментариев
  comments:
    # Минимум 1 пробел между # и текстом комментария
    min-spaces-from-content: 1
  
  # Правила для переносов строк
  new-lines:
    # Unix-стиль (LF вместо CRLF)
    type: unix
  
  # Правила для отступов
  indentation:
    # 2 пробела на уровень
    spaces: 2
    # Не проверять многострочные строки (важно для GitHub Actions)
    check-multi-line-strings: false
